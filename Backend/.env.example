# ─────────────────────────────────────────────────────────────────────────────
# Loa Design Backend — variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados (PostgreSQL) ───────────────────────────────────────────────
# Local com Docker (use o docker-compose.yml deste diretório):
DATABASE_URL="postgresql://loa:loa@localhost:5432/loadesign?schema=public"
#
# Neon (https://neon.tech) — copie a connection string do dashboard:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/loadesign?sslmode=require"
#
# Supabase:
# DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Railway / Render Postgres:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=development

# ── CORS — múltiplas origens separadas por vírgula ───────────────────────────
# Local: site público (5173) + admin (5174)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
#
# Produção (exemplo):
# CORS_ORIGIN=https://loadesign.com.br,https://admin.loadesign.com.br

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere uma chave forte de 64 bytes:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NUNCA suba a chave de produção no git.
JWT_SECRET=TROQUE_ESTA_CHAVE_em_producao_use_random_de_64_bytes_em_hex
JWT_EXPIRES_IN=7d
